{
  "hcs": {
    "cpus": 4,
    "ram_mb": 2048,
    "gpu_mode": "none",
    "name": "chimera_cuttlefish"
  },
  "boot": {
    "kernel": "out/android-kernel/bzImage",
    "initrd": "out/cuttlefish/initrd.img",
    "cmdline": "console=ttyS0,115200n8 earlycon=uart8250,io,0x3f8,115200 loglevel=8 ignore_loglevel panic=30 init=/init androidboot.selinux=permissive"
  },
  "disks": {
    "system":   "out/cuttlefish/system.vhdx",
    "vendor":   "out/cuttlefish/vendor.vhdx",
    "userdata": "out/cuttlefish/userdata.vhdx"
  }
}
